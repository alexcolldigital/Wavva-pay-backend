# Copy this file to .env and fill in your values
# cp .env.example .env

# Core
NODE_ENV=development
PORT=4000
MONGODB_URI=mongodb://localhost:27017/wavva-pay
JWT_SECRET=your_jwt_secret_minimum_32_characters
JWT_EXPIRE=7d
ENCRYPTION_KEY=your_32_character_encryption_key
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001,http://localhost:8081

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback

# Flutterwave
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-your_key
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-your_key
FLUTTERWAVE_BASE_URL=https://api.flutterwave.com/v3

# Wema Bank (ALAT)
WEMA_SUBSCRIPTION_KEY=your_wema_subscription_key
WEMA_API_KEY=your_wema_api_key
WEMA_API_SECRET=your_wema_api_secret
WEMA_MERCHANT_ID=your_wema_merchant_id
WEMA_BASE_URL=https://wema-alatdev-apimgt.developer.azure-api.net/
WEMA_SETTLEMENT_ACCOUNT_NUMBER=your_settlement_account_number
WEMA_SETTLEMENT_ACCOUNT_NAME=Wavva Pay Settlement

# Wema Product Codes
WEMA_OPEN_BANKING_PRODUCT_CODE=your_code
WEMA_NIP_TRANSFER_PRODUCT_CODE=your_code
WEMA_ACCOUNT_VERIFICATION_PRODUCT_CODE=your_code
WEMA_BANK_LIST_PRODUCT_CODE=your_code
WEMA_SETTLEMENT_PRODUCT_CODE=your_code
WEMA_CUSTOMER_IDENTIFICATION_PRODUCT_CODE=your_code

# Cloudinary (image storage)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Twilio (SMS/WhatsApp)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=whatsapp:+1234567890

# Email
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_specific_password

# Redis (optional, for caching)
REDIS_URL=redis://localhost:6379

# CBN Compliance
CBN_REPORTING_ENDPOINT=https://api.cbn.gov.ng/reporting
CBN_API_KEY=your_cbn_api_key
CBN_INSTITUTION_CODE=your_institution_code

# KYC Services
SMILE_IDENTITY_API_KEY=your_smile_identity_key
SMILE_IDENTITY_PARTNER_ID=your_partner_id
SMILE_IDENTITY_BASE_URL=https://3eydmgh10d.execute-api.us-west-2.amazonaws.com/test

# Sanctions Screening
WORLD_CHECK_API_KEY=your_world_check_key
WORLD_CHECK_BASE_URL=https://api-worldcheck.refinitiv.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
