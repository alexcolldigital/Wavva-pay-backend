# MongoDB Configuration
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/wavva_pay

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters
JWT_EXPIRE=7d

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Chimoney Configuration (Sandbox for development)
CHIMONEY_API_KEY=your-chimoney-sandbox-key
CHIMONEY_BASE_URL=https://api-v2-sandbox.chimoney.io/v0.2

# Twilio Configuration
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=whatsapp:+1234567890

# Email Configuration
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password

# Stripe Configuration (Optional, for future use)
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_PUBLIC_KEY=pk_test_your_stripe_key

# Application Configuration
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:8081
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006

# Security Configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging Configuration
LOG_LEVEL=info
SENTRY_DSN=your-sentry-dsn-optional

# Redis Configuration (Optional, for caching)
REDIS_URL=redis://localhost:6379
