{
  "name": "wavva-pay-backend",
  "version": "1.0.0",
  "description": "Venom-themed social payment app backend",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "build": "npm install",
    "seed": "node scripts/seed.js",
    "test": "jest --coverage --detectOpenHandles",
    "test:watch": "jest --watch",
    "test:integration": "jest tests/integration.test.js",
    "db:setup": "node src/config/database.js",
    "docker:build": "docker build -t wavva-pay .",
    "docker:deploy": "docker-compose up -d",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix"
  },
  "keywords": [
    "payments",
    "social",
    "venom",
    "wavva"
  ],
  "author": "Wavva Pay Team",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.0.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.0.0",
    "multer": "^2.0.2",
    "mysql2": "^3.16.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^7.0.13",
    "redis": "^4.6.0",
    "sequelize": "^6.37.7",
    "socket.io": "^4.8.2",
    "streamifier": "^0.1.1",
    "stripe": "^13.10.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "twilio": "^4.19.0",
    "uuid": "^9.0.1",
    "validator": "^13.11.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "eslint": "^9.39.2",
    "jest": "^29.7.0",
    "nock": "^13.5.6",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
